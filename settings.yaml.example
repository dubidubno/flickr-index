site_title: "My Photos"
author: ""                  # Shown in footer, e.g. "Jane Doe"
output_dir: "output"
flickr_user_id: ""          # Your Flickr NSID, e.g. 12345678@N00
thumb_size: "q"             # q = 150x150 square thumbnail
large_size: "b"             # b = 1024px longest edge
photos_per_page: 24
base_path: ""               # URL prefix, e.g. "/flickr-photos" (no trailing slash)
site_url: ""                # Absolute base URL, e.g. "https://example.com" (no trailing slash)
notify_email_to: ""             # e.g. "you@example.com" — leave empty to disable
notify_email_from: ""           # e.g. "flickr-index@example.com"
notify_smtp_host: "localhost"
notify_smtp_port: 25
